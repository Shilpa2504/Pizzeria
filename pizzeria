import { Component, OnInit } from '@angular/core';
import { FetchdataService, User, Address } from '../fetchdata.service';
import { Router } from '@angular/router';

@Component({
  selector: 'app-profile',
  templateUrl: './profile.component.html',
  styleUrls: ['./profile.component.css']
})
export class ProfileComponent implements OnInit {

  user: User | null = null;
  addresses: Address[] = [];
  isLoading = false;
  isEditing = false;
  showAddressForm = false;
  successMessage = '';
  errorMessage = '';

  editingUser: User = { name: '', email: '', phone: '' };
  newAddress: Address = { street: '', city: '', state: '', zip: '', country: '' };

  constructor(private fd: FetchdataService, private router: Router) {}

  ngOnInit(): void {
    this.loadUserProfile();
  }

  loadUserProfile(): void {
    this.isLoading = true;
    const userData = localStorage.getItem('user');
    if (!userData) { this.router.navigate(['/login']); return; }
    try {
      this.user = JSON.parse(userData);
      if (this.user) {
        this.editingUser = { ...this.user };
        this.loadAddresses();
      }
    } catch (error) {
      this.errorMessage = 'Failed to load user profile';
    }
    this.isLoading = false;
  }

  loadAddresses(): void {
    if (!this.user || !this.user._id) return;
    this.fd.getUserAddresses(this.user._id).subscribe(
      (addresses: Address[]) => { this.addresses = addresses; },
      (error) => { console.error('Error loading addresses:', error); }
    );
  }

  toggleEdit(): void {
    this.isEditing = !this.isEditing;
    if (!this.isEditing) { this.editingUser = { ...this.user! }; this.errorMessage = ''; }
  }

  saveProfile(): void {
    if (!this.user || !this.user._id) return;
    if (!this.editingUser.name || !this.editingUser.email) {
      this.errorMessage = 'Name and email are required'; return;
    }
    this.isLoading = true;
    this.fd.updateUserProfile(this.user._id, this.editingUser).subscribe(
      () => {
        this.user = this.editingUser;
        localStorage.setItem('user', JSON.stringify(this.user));
        this.isEditing = false;
        this.successMessage = 'Profile updated successfully!';
        setTimeout(() => this.successMessage = '', 3000);
      },
      () => { this.errorMessage = 'Failed to update profile.'; },
      () => { this.isLoading = false; }
    );
  }

  toggleAddressForm(): void {
    this.showAddressForm = !this.showAddressForm;
    if (!this.showAddressForm) this.resetAddressForm();
  }

  addAddress(): void {
    if (!this.user || !this.user._id) return;
    if (!this.newAddress.street || !this.newAddress.city || !this.newAddress.zip) {
      this.errorMessage = 'Please fill all required fields'; return;
    }
    this.fd.addUserAddress(this.user._id, this.newAddress).subscribe(
      (address: Address) => {
        this.addresses.push(address);
        this.showAddressForm = false;
        this.resetAddressForm();
        this.successMessage = 'Address added!';
        setTimeout(() => this.successMessage = '', 3000);
      },
      () => { this.errorMessage = 'Failed to add address.'; }
    );
  }

  deleteAddress(addressId: string | undefined): void {
    if (!this.user?._id || !addressId) return;
    this.fd.deleteUserAddress(this.user._id, addressId).subscribe(
      () => { this.addresses = this.addresses.filter(a => a._id !== addressId); },
      () => { this.errorMessage = 'Failed to delete address.'; }
    );
  }

  resetAddressForm(): void {
    this.newAddress = { street: '', city: '', state: '', zip: '', country: '' };
  }

  goToOrderHistory(): void { this.router.navigate(['/order-history']); }

  logoutUser(): void {
    localStorage.removeItem('user');
    this.router.navigate(['/login']);
  }
}
