  expandedOrderId: string | null = null;

  statusConfig: any = {
    'pending': { badge: 'warning', icon: 'fas fa-clock', label: 'Pending' },
    'confirmed': { badge: 'info', icon: 'fas fa-check-circle', label: 'Confirmed' },
    'preparing': { badge: 'info', icon: 'fas fa-utensils', label: 'Preparing' },
    'out-for-delivery': { badge: 'primary', icon: 'fas fa-truck', label: 'Out for Delivery' },
    'delivered': { badge: 'success', icon: 'fas fa-check', label: 'Delivered' },
    'cancelled': { badge: 'danger', icon: 'fas fa-times', label: 'Cancelled' }
  };

  constructor(private fd: FetchdataService, private router: Router) {}

  ngOnInit(): void { this.loadOrderHistory(); }

  loadOrderHistory(): void {
    const userData = localStorage.getItem('user');
    if (!userData) { this.router.navigate(['/login']); return; }
    try {
      const user = JSON.parse(userData);
      if (!user._id) { this.router.navigate(['/login']); return; }
      this.isLoading = true;
      this.fd.getOrderHistory(user._id).subscribe(
        (orders: Order[]) => {
          this.orders = orders.sort((a, b) =>
            new Date(b.createdAt || '').getTime() - new Date(a.createdAt || '').getTime());
          this.applyStatusFilter();
        },
        () => { this.errorMessage = 'Failed to load order history.'; },
        () => { this.isLoading = false; }
      );
    } catch (e) { this.router.navigate(['/login']); }
  }

  applyStatusFilter(): void {
    this.filteredOrders = this.statusFilter === 'all'
      ? [...this.orders]
      : this.orders.filter(o => o.status === this.statusFilter);
  }

  toggleOrderDetails(orderId: string | undefined): void {
    if (!orderId) return;
    this.expandedOrderId = this.expandedOrderId === orderId ? null : orderId;
  }

  isOrderExpanded(orderId: string | undefined): boolean {
    return this.expandedOrderId === orderId;
  }

  getStatusBadgeClass(status: string): string {
    return `bg-${this.statusConfig[status]?.badge || 'secondary'}`;
  }

  getStatusIcon(status: string): string {
    return this.statusConfig[status]?.icon || 'fas fa-question';
  }

  getStatusLabel(status: string): string {
    return this.statusConfig[status]?.label || status;
  }

  formatDate(date: Date | undefined): string {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  getDaysSinceOrder(date: Date | undefined): string {
    if (!date) return '';
    const days = Math.floor((Date.now() - new Date(date).getTime()) / (1000 * 60 * 60 * 24));
    return days === 0 ? 'Today' : days === 1 ? 'Yesterday' : `${days} days ago`;
  }
}
