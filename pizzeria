// Generated by GitHub Copilot
import { Component, OnInit } from '@angular/core';
import { FetchdataService, Pizza } from '../fetchdata.service';
import { ShoppingCartService } from '../shopping-cart.service';

@Component({
  selector: 'app-orderpizza',
  templateUrl: './orderpizza.component.html',
  styleUrls: ['./orderpizza.component.css']
})
export class OrderpizzaComponent implements OnInit {

  orderPizzaData: Pizza[] = [];
  filteredPizzas: Pizza[] = [];
  searchQuery: string = '';
  notFetched = true;
  isLoading = false;
  errorMessage: string = '';

  selectedVegetarian: boolean | null = null;
  maxPriceFilter: number = 1000;
  sortBy: 'name' | 'price' | 'rating' = 'name';

  cartData: any[] = [];
  pizzaQuantities: { [key: string]: number } = {};

  constructor(
    private readonly fd: FetchdataService,
    private readonly cartService: ShoppingCartService
  ) {}

  ngOnInit(): void {
    this.loadPizzas();
    this.cartService.getCart$().subscribe(() => {
      this.syncQuantitiesFromCart();
    });
  }

  loadPizzas(): void {
    this.isLoading = true;
    this.errorMessage = '';
    this.fd.fetchOrderPizza().subscribe(
      (resp: Pizza[]) => {
        this.orderPizzaData = resp;
        this.filteredPizzas = resp;
        this.notFetched = false;
        this.applyFilters();
      },
      (error) => {
        console.error('Error fetching pizzas:', error);
        this.errorMessage = 'Failed to load pizzas. Please try again.';
        this.notFetched = true;
      },
      () => {
        this.isLoading = false;
      }
    );
  }

  onSearch(): void {
    this.applyFilters();
  }

  applyFilters(): void {
    this.filteredPizzas = this.orderPizzaData.filter(pizza => {
      if (this.searchQuery && !pizza.name.toLowerCase().includes(this.searchQuery.toLowerCase())) {
        return false;
      }
      if (this.selectedVegetarian !== null && this.isVeg(pizza) !== this.selectedVegetarian) {
        return false;
      }
      if (pizza.price > this.maxPriceFilter) {
        return false;
      }
      return true;
    });
    this.sortPizzas();
  }

  sortPizzas(): void {
    this.filteredPizzas.sort((a, b) => {
      switch (this.sortBy) {
        case 'price': return a.price - b.price;
        case 'rating': {
          const ratingA = a.rating || 0;
          const ratingB = b.rating || 0;
          return ratingB - ratingA;
        }
        case 'name':
        default: return a.name.localeCompare(b.name);
      }
    });
  }

  isVeg(pizza: Pizza): boolean {
    if (typeof pizza.vegetarian === 'boolean') return pizza.vegetarian;
    if (pizza.type) return pizza.type.toLowerCase() === 'veg';
    return false;
  }

  getAverageRating(pizza: Pizza): number {
    if (!pizza.reviews || pizza.reviews.length === 0) return 0;
    const sum = pizza.reviews.reduce((acc, review) => acc + review.rating, 0);
    return sum / pizza.reviews.length;
  }

  getRatingStars(rating: number): number[] {
    return new Array(5).fill(0).map((_, i) => i < Math.round(rating) ? 1 : 0);
  }

  getReviewCount(pizza: Pizza): number {
    return pizza.reviews?.length || 0;
  }

  addToCart(pizza: Pizza): void {
    const pizzaId = pizza._id || pizza.name;
    const currentQty = this.getQuantity(pizza);
    if (currentQty === 0) {
      const cartItem = {
        id: pizzaId,
        name: pizza.name,
        price: pizza.price,
        quantity: 1,
        image: pizza.image,
        type: 'preset' as const
      };
      this.cartService.addToCart(cartItem);
      this.pizzaQuantities[pizzaId] = 1;
    } else {
      this.incrementQuantity(pizza);
    }
  }

  private syncQuantitiesFromCart(): void {
    const cartItems = this.cartService.getCart();
    this.pizzaQuantities = {};
    cartItems.forEach(item => {
      if (item.type === 'preset') {
        this.pizzaQuantities[item.id] = item.quantity;
      }
    });
  }

  getQuantity(pizza: Pizza): number {
    const pizzaId = pizza._id || pizza.name;
    return this.pizzaQuantities[pizzaId] || 0;
  }

  isInCart(pizza: Pizza): boolean {
    return this.getQuantity(pizza) > 0;
  }

  incrementQuantity(pizza: Pizza): void {
    const pizzaId = pizza._id || pizza.name;
    const currentQty = this.getQuantity(pizza);
    this.cartService.updateQuantity(pizzaId, currentQty + 1);
    this.pizzaQuantities[pizzaId] = currentQty + 1;
  }

  decrementQuantity(pizza: Pizza): void {
    const pizzaId = pizza._id || pizza.name;
    const currentQty = this.getQuantity(pizza);
    if (currentQty <= 1) {
      this.cartService.removeFromCart(pizzaId);
      delete this.pizzaQuantities[pizzaId];
    } else {
      this.cartService.updateQuantity(pizzaId, currentQty - 1);
      this.pizzaQuantities[pizzaId] = currentQty - 1;
    }
  }

  updateQuantity(pizza: Pizza, newQuantity: number): void {
    const pizzaId = pizza._id || pizza.name;
    if (newQuantity <= 0) {
      this.cartService.removeFromCart(pizzaId);
      delete this.pizzaQuantities[pizzaId];
    } else {
      this.cartService.updateQuantity(pizzaId, newQuantity);
      this.pizzaQuantities[pizzaId] = newQuantity;
    }
  }

  clearFilters(): void {
    this.searchQuery = '';
    this.selectedVegetarian = null;
    this.maxPriceFilter = 1000;
    this.sortBy = 'name';
    this.applyFilters();
  }
}
